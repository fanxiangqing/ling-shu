# Copy to .env and adjust values: cp .env.example .env
# .env is ignored by Git; never commit real secrets.

# Image tag for the built api/web images
LING_SHU_IMAGE_TAG=latest

# Exposed host ports
LING_SHU_API_PORT=8080
LING_SHU_WEB_PORT=80
LING_SHU_MYSQL_PORT=3306
LING_SHU_REDIS_PORT=6379
LING_SHU_MILVUS_PORT=19530

# Logging
LING_SHU_LOG_LEVEL=info

# Database
MYSQL_ROOT_PASSWORD=change-me
# Optional: override the full DSN (defaults to the bundled mysql service)
# LING_SHU_MYSQL_DSN=root:change-me@tcp(mysql:3306)/ling_shu?charset=utf8mb4&parseTime=true&loc=Local

# Required secrets (no defaults, container will refuse to start without them)
LING_SHU_JWT_SECRET=change-me-jwt
LING_SHU_DSN_SECRET=change-me-dsn

# Milvus / RAG
LING_SHU_MILVUS_ENABLED=true
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Aliyun LLM / ASR / TTS (optional)
LING_SHU_ALIYUN_API_KEY=
LING_SHU_ASR_ENABLED=false
LING_SHU_TTS_ENABLED=false
ALIYUN_AK_ID=
ALIYUN_AK_SECRET=
LING_SHU_ALIYUN_NLS_APP_KEY=
